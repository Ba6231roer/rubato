mcp:
  servers:
    playwright:
      enabled: true
      command: "npx"
      args:
        - "-y"
        - "@playwright/mcp"
        - "--caps=testing"
      
      connection:
        retry_times: 3
        retry_delay: 5
        timeout: 30

