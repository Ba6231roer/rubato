# skills:
#   directory: "skills/api"
#   enabled_skills:
#     - api-testing
#     - data-validation
#   skill_loading:
#     max_loaded_skills: 3
#   self_improve:
#     nudge_interval: 30
#     background_review:
#       enabled: false
