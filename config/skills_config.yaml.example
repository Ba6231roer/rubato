# ========================================
# Skills 配置示例文件
# ========================================
# 本文件展示了 SkillsConfig 的完整配置选项
# 复制此文件为 skills_config.yaml 并根据实际需求修改

# ========================================
# Skills 配置
# ========================================
skills:
  directory: "skills"

  # ========================================
  # 禁用的技能列表（黑名单）
  # ========================================
  # 列出不需要加载的 Skill 名称，这些 Skill 不会出现在系统提示词中
  # 默认为空（加载所有 Skill），与 self_improve 自创建 Skill 机制一致
  # Agent 通过 skill_manage 创建的 Skill 自动注册，无需手动配置
  disabled_skills: []
  #   - legacy-test         # 示例：禁用旧的测试 Skill
  #   - deprecated-query    # 示例：禁用已废弃的查询 Skill

  # ========================================
  # 自我改进配置
  # ========================================
  # 控制运行时 Skill 的自动创建/更新行为。
  # 工作机制：Agent 执行工具调用时，内部计数器累加。当达到 nudge_interval 阈值时，
  # 根据 background_review.enabled 决定触发方式：
  #   - background_review.enabled=false: 向 Agent 返回一条 nudge 提示，由 Agent 自行判断是否调用 skill_manage
  #   - background_review.enabled=true:  后台 fork 一个审查 Agent，独立审查对话历史并决定是否创建/更新 Skill
  # 无论哪种方式，都只有"需要反复尝试才能成功的操作"才应保存为 Skill，常规流程不会产生 Skill。
  #
  # 典型测试案例场景分析（30~50 步骤，60+ 工具调用）：
  #   - 大部分工具调用是 playwright-cli + file_read 的常规操作序列（点击→截图→读结果），
  #     属于流程性操作，不涉及试错，不会也不应产生 Skill。
  #   - 只有遇到难以定位的元素、需要特殊 CSS 选择器技巧、或需要多轮调试才能通过的步骤，
  #     才可能触发 Skill 保存。
  #   - nudge_interval=30 意味着约每 30 次工具调用才触发一次审查/提示，
  #     对于 60+ 次调用的案例，最多触发 2 次，不会导致"每个案例都变成 Skill"。
  #   - 可在测试案例文档中添加 [参考skill] 章节引用 Skill 名称，
  #     下次执行该案例时会自动加载对应 Skill 的完整内容。
  self_improve:
    nudge_interval: 30

    background_review:
      enabled: false
      max_iterations: 8

# ========================================
# 完整配置示例
# ========================================

# 示例 1: Web 自动化测试项目（推荐）
# skills:
#   directory: "skills"
#   disabled_skills: []
#   self_improve:
#     nudge_interval: 30
#     background_review:
#       enabled: false

# 示例 2: 启用后台审查（适合长对话/探索性任务）
# skills:
#   directory: "skills"
#   disabled_skills: []
#   self_improve:
#     nudge_interval: 30
#     background_review:
#       enabled: true
#       max_iterations: 8

# 示例 3: 禁用特定 Skill
# skills:
#   directory: "skills"
#   disabled_skills:
#     - legacy-test
#   self_improve:
#     nudge_interval: 30

# 示例 4: 禁用自我改进
# skills:
#   directory: "skills"
#   disabled_skills: []
#   self_improve:
#     nudge_interval: 0
