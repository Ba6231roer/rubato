# ============================================================
# Rubato 统一工具配置示例文件
# ============================================================
# 本文件展示了所有工具配置项的完整示例
# 复制此文件为 tools_config.yaml 并根据需要修改
# ============================================================

tools:
  # ============================================================
  # 内置工具配置
  # ============================================================
  builtin:
    # 是否启用内置工具
    # 内置工具包括：spawn_agent、shell_tool、file_tools
    enabled: true

    # spawn_agent 工具配置
    # 用于创建子代理执行特定任务
    spawn_agent:
      # 是否启用 spawn_agent 工具
      enabled: true

    # Shell 工具配置
    # 用于执行系统命令
    shell_tool:
      # 是否启用 Shell 工具
      enabled: true
      # 安全模式：启用后将限制危险命令的执行
      safe_mode: true
      # 允许执行的命令白名单
      # 留空表示在安全模式下允许所有非危险命令
      # 指定后将只允许执行白名单中的命令
      allowed_commands: []
      # allowed_commands 示例：
      # allowed_commands:
      #   - git
      #   - npm
      #   - python
      #   - pip

    # 文件工具配置
    # 用于文件读写、搜索等操作
    file_tools:
      # 是否启用文件工具
      enabled: true
      # 默认权限模式
      # 可选值：
      #   - ask: 每次操作前询问用户确认
      #   - allow: 自动允许所有操作
      #   - deny: 自动拒绝所有操作
      permission_mode: "ask"
      # 工作区配置（可选）
      # workspace:
      #   # 主工作区路径（必填）
      #   main: /path/to/workspace
      #   # 额外的工作区路径列表
      #   additional:
      #     - /path/to/extra/workspace1
      #     - /path/to/extra/workspace2
      #   # 排除的路径模式（支持 glob 模式）
      #   excluded:
      #     - "**/node_modules/**"
      #     - "**/.git/**"
      #     - "**/__pycache__/**"
      workspace: null
      # 路径权限配置
      # 格式为 "操作:路径模式": 权限
      # 操作类型：read、write、delete、move、list、search、exists
      # 路径模式支持 glob 匹配，* 表示匹配所有
      # 权限值：allow（允许）、ask（询问）、deny（拒绝）
      permissions:
        "read:*": "allow"
        "list:*": "allow"
        "search:*": "allow"
        "exists:*": "allow"
        "write:*.md": "ask"
        "write:*.py": "ask"
        "write:*.txt": "allow"
        "write:*.log": "allow"
        "delete:*": "deny"
        "move:*": "ask"
      # 是否启用审计日志
      # 启用后将记录所有文件操作到日志
      audit: true

  # ============================================================
  # MCP (Model Context Protocol) 工具配置
  # ============================================================
  mcp:
    # 是否自动连接 MCP 服务器
    # 启用后将在启动时自动连接配置的服务器
    auto_connect: true

  # ============================================================
  # Skills 技能配置
  # ============================================================
  skills: {}

  # ============================================================
  # 工具说明文档配置
  # ============================================================
  tool_docs:
    # 是否自动注入工具说明文档
    # 启用后将在系统提示中自动添加工具使用说明
    auto_inject: true
    # 是否在文档中包含使用示例
    include_examples: true

# ============================================================
# 完整配置示例（取消注释以使用）
