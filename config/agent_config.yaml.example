# ============================================================
# Agent 配置示例文件
# ============================================================
# 本文件包含 Agent 运行时的各项配置参数
# 复制此文件为 agent_config.yaml 并根据需要修改

agent:
  # ============================================================
  # 上下文配置
  # ============================================================
  # Agent 最大上下文 token 数量
  # - 决定了 Agent 能够处理的最大上下文窗口大小
  # - 超过此限制时将触发消息压缩机制
  # - 建议值：200000（适用于大多数现代 LLM）
  # max_context_tokens: 200000

  # ============================================================
  # 消息压缩配置
  # ============================================================
  message_compression:
    # 是否启用消息压缩功能
    # - 当上下文接近 max_context_tokens 时自动压缩历史消息
    # - 建议保持启用以避免超出 token 限制
    enabled: true

    # 保留最近 N 条消息不压缩
    # - 这些消息将保持原样，确保最近上下文的完整性
    # - 建议值：6（保留最近 3 轮对话）
    keep_recent: 6

    # 自动压缩缓冲 token 数
    # - 当上下文 token 数超过 max_context_tokens - autocompact_buffer_tokens 时触发自动压缩
    # - 值越大，压缩触发越早，留给后续对话的空间越多
    # - 建议值：13000
    autocompact_buffer_tokens: 13000

    # 手动压缩缓冲 token 数
    # - 手动触发压缩时的目标缓冲空间
    # - 通常小于自动压缩缓冲，压缩更彻底
    # - 建议值：3000
    manual_compact_buffer_tokens: 3000

    # 上下文告警阈值缓冲 token 数
    # - 当上下文 token 数超过 max_context_tokens - warning_threshold_buffer_tokens 时发出告警
    # - 值越大，告警越早，提醒用户注意上下文使用情况
    # - 建议值：20000
    warning_threshold_buffer_tokens: 20000

    # 裁剪保留最近消息数
    # - 执行轻量裁剪（snip）时保留的最近消息数量
    # - 裁剪是比完整压缩更轻量的上下文缩减方式
    # - 建议值：6
    snip_keep_recent: 6

    # 工具结果持久化阈值（字符数）
    # - 工具结果超过此字符数时，将内容持久化到磁盘而非保留在内存中
    # - 有助于控制上下文大小，避免大型工具输出占用过多 token
    # - 建议值：50000
    tool_result_persist_threshold: 50000

    # 每条消息的工具结果预算（字符数）
    # - 单条消息中工具结果的最大总字符数
    # - 超过预算的工具结果将被持久化到磁盘
    # - 建议值：200000
    tool_result_budget_per_message: 200000

    # 最大连续压缩失败次数
    # - 连续压缩失败达到此次数后，跳过后续自动压缩尝试
    # - 防止在 LLM 不可用时反复尝试压缩导致性能问题
    # - 建议值：3
    max_consecutive_failures: 3

    # 大消息字符阈值
    # - 超过此字符数的人类消息将在压缩前被截断
    # - 截断时保留前 10000 字符并标注原始大小
    # - 压缩摘要和任务意图消息不受此阈值影响
    # - 建议值：50000
    large_message_char_threshold: 50000

    # Skill 过期超时时间（秒）
    # - 已加载的 Skill 超过此时间未被引用将被视为过期
    # - 过期 Skill 会在下次系统提示词重建时被卸载
    # - 建议值：300（5分钟）
    skill_stale_timeout_seconds: 300

    # 任务意图保护配置
    # - 在上下文压缩时保护原始任务意图不被丢失
    # - 压缩后会自动恢复任务意图到上下文中
    task_intent_protection:
      # 是否启用任务意图保护
      enabled: true

      # 全量存储字符阈值
      # - 任务意图字符数不超过此值时，完整保留在上下文中
      # - 超过此值时，将任务意图持久化到磁盘，上下文中仅保留预览
      # - 建议值：2000
      full_threshold: 2000

      # 任务意图恢复 token 预算
      # - 压缩后恢复任务意图时允许的最大 token 数
      # - 超过预算时将截断或引用持久化文件
      # - 建议值：10000
      token_budget: 10000

  # ============================================================
  # 执行参数配置
  # ============================================================
  execution:
    # Agent 递归调用限制
    # - 防止无限递归导致资源耗尽
    # - 当 Agent 调用链达到此深度时将停止
    # - 建议值：100
    recursion_limit: 100

    # 子 Agent 递归调用限制
    # - 子 Agent（spawn_agent 创建）的最大递归深度
    # - 通常设置为主 Agent 限制的一半
    # - 建议值：50
    sub_agent_recursion_limit: 50

    # LLM 调用超时时间（秒）
    # - 单次 LLM 流式调用的最大等待时间
    # - 超过此时间将中断操作并报错
    # - 建议值：300（5分钟）
    llm_timeout: 300

  # ============================================================
  # 日志配置
  # ============================================================
  logging:
    # 是否记录 token 估算信息
    # - 记录每次操作的 token 使用估算
    # - 有助于监控资源使用情况
    log_token_estimation: true

    # 是否记录压缩统计信息
    # - 记录消息压缩前后的 token 数量变化
    # - 有助于评估压缩效果
    log_compression_stats: true

    # 是否记录步骤详情
    # - 记录 Agent 每个执行步骤的详细信息
    # - 有助于调试和分析 Agent 行为
    log_step_details: true

    # 是否记录 Skill 生命周期事件
    # - 记录 Skill 的加载、卸载、过期等生命周期事件
    # - 有助于调试 Skill 管理问题
    log_skill_lifecycle: true

    # 日志格式
    # - compact: 紧凑模式，使用键值对格式，减少每个日志占用的行数
    # - detailed: 详细模式，使用 JSON 格式，保留完整结构信息
    # - 建议值：compact（便于快速浏览）
    log_format: compact

    # 工具日志模式
    # - summary: 摘要模式，工具列表以摘要形式显示
    # - detailed: 详细模式，打印完整的工具定义信息
    # - 建议值：summary（减少日志冗余）
    tool_log_mode: summary

# ============================================================
# 配置场景示例
# ============================================================

