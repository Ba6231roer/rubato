# ========================================
# Project 配置示例文件
# ========================================
# 本文件展示了 ProjectConfig 的完整配置选项
# 复制此文件为 project_config.yaml 并根据实际需求修改

# ========================================
# 项目配置
# ========================================
project:
  # 项目名称
  # 用于标识项目，在日志和提示词中使用
  name: "rubato"
  
  # 项目根目录
  # 定义项目的根目录路径
  # 支持相对路径（相对于配置文件位置）或绝对路径
  # "." 表示配置文件所在的目录
  root: "."
  
  # 不同场景示例：
  # - 使用绝对路径
  # root: "/home/user/projects/myapp"
  
  # - 使用相对路径
  # root: ".."  # 配置文件的上级目录
  
  # ========================================
  # 工作空间配置
  # ========================================
  # 定义 Agent 可以访问的文件范围，确保安全性
  workspace:
    # 主工作空间路径
    # Agent 的所有文件操作（读、写、删除等）都限制在此路径内
    # 这是最重要的安全边界
    main: "."
    
    # 不同场景示例：
    # - 限制在 src 目录
    # main: "./src"
    
    # - 限制在项目根目录
    # main: "/home/user/projects/myapp"
    
    # 附加工作空间列表（可选）
    # 允许 Agent 访问主工作空间之外的其他目录
    # 用于访问共享资源、配置文件等
    additional:
      - "./src"
      - "./config"
    
    # 不同场景示例：
    # - 包含测试目录
    # additional:
    #   - "./src"
    #   - "./tests"
    #   - "./config"
    
    # - 包含外部资源目录
    # additional:
    #   - "./src"
    #   - "/shared/resources"
    #   - "/home/user/documents"
    
    # - 不使用附加工作空间
    # additional: []
    
    # 排除的文件和目录模式（可选）
    # 匹配这些模式的文件/目录将被禁止访问
    # 支持通配符模式
    excluded:
      - "node_modules"      # Node.js 依赖目录
      - ".git"              # Git 仓库目录
      - "__pycache__"       # Python 缓存目录
      - "*.pyc"             # Python 编译文件
      - ".venv"             # Python 虚拟环境
      - "venv"              # Python 虚拟环境
    
    # 不同场景示例：
    # - Web 项目排除模式
    # excluded:
    #   - "node_modules"
    #   - ".git"
    #   - "dist"
    #   - "build"
    #   - ".next"
    #   - "*.log"
    
    # - Python 项目排除模式
    # excluded:
    #   - "__pycache__"
    #   - "*.pyc"
    #   - "*.pyo"
    #   - ".venv"
    #   - "venv"
    #   - ".pytest_cache"
    #   - "*.egg-info"
    
    # - 严格安全模式
    # excluded:
    #   - ".*"               # 排除所有隐藏文件和目录
    #   - "*.key"            # 排除密钥文件
    #   - "*.pem"            # 排除证书文件
    #   - "*.env"            # 排除环境变量文件
    #   - "secrets"          # 排除机密目录

# ========================================
# 完整配置示例
# ========================================

# 示例 1: 单体应用项目
# project:
#   name: "monolith-app"
#   root: "."
#   workspace:
#     main: "."
#     additional:
#       - "./src"
#       - "./config"
#       - "./tests"
#     excluded:
#       - "node_modules"
#       - ".git"
#       - "__pycache__"
#       - "*.pyc"

