# ========================================
# Rubato 模型配置示例文件
# ========================================
# 此文件展示了如何配置 Rubato 的模型设置
# 复制此文件为 model_config.yaml 并根据需要修改配置

# ========================================
# 主模型配置
# ========================================
model:
  # 模型提供商 (必填)
  # 可选值: 'openai', 'anthropic', 'local'
  provider: "openai"
  
  # 模型名称 (必填)
  # 根据提供商选择对应的模型
  name: "gpt-4"
  
  # API 密钥 (必填)
  # 推荐使用环境变量，避免硬编码密钥
  # 使用 ${环境变量名} 格式引用环境变量
  api_key: "${OPENAI_API_KEY}"
  
  # 认证方式 (可选)
  # 某些提供商可能需要特殊的认证头
  auth: null
  
  # API 基础 URL (可选)
  # 用于自定义 API 端点或代理
  base_url: null
  
  # 温度参数 (可选，默认: 0.7)
  temperature: 0.7
  
  # 最大令牌数 (可选，默认: 2000)
  max_tokens: 2000

# ========================================
# 模型参数配置
# ========================================
parameters:
  # LLM 调用超时时间 (默认: 300.0 秒)
  # 单次 LLM 流式调用的最大等待时间
  # 超过此时间将触发超时重试
  llm_timeout: 300.0
  
  # 最大重试次数 (默认: 3)
  # LLM 调用超时后的最大重试次数
  retry_max_count: 3
  
  # 初始重试等待时间 (默认: 10.0 秒)
  # 首次重试前的等待时间
  retry_initial_delay: 10.0
  
  # 单次重试最大等待时间 (默认: 60.0 秒)
  # 每次重试等待时间翻倍，但不超过此值
  # 例如: 初始10秒 -> min(20, 60)=20秒 -> min(40, 60)=40秒 -> min(80, 60)=60秒
  retry_max_delay: 60.0

# ========================================
# 多种模型提供商配置示例
# ========================================

